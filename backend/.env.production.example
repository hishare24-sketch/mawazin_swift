# ===== قالب بيئة الإنتاج (Render + Supabase + Resend + Firebase) =====
# لا تُخزَّن القيم الحقيقيّة هنا — تُلصَق في لوحة Render (Environment) أو مجموعة البيئة.
# هذا الملفّ توثيقيّ فقط: يوضّح كلّ مفتاح مطلوب.

APP_NAME="منظومة التوظيف الذكية"
APP_ENV=production
APP_KEY=                       # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://api.example.com
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stderr             # Render يلتقط stdout/stderr
LOG_LEVEL=warning

# ——— قاعدة Supabase (Postgres) ———
DB_CONNECTION=pgsql
DB_HOST=db.xxxxxxxx.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=
DB_SSLMODE=require

# ——— الجلسة/الكاش/الطابور ———
SESSION_DRIVER=database
CACHE_STORE=redis
QUEUE_CONNECTION=redis
REDIS_URL=                     # يحقنه Render من خدمة redis

# ——— البثّ اللحظيّ (Reverb) ———
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=ws.example.com     # دومين خدمة reverb العامّة
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
# REVERB_SERVER_PORT يمرّره Render كـ $PORT في أمر reverb:start

# ——— البريد (Resend) ———
MAIL_MAILER=resend
RESEND_API_KEY=
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="منظومة التوظيف الذكية"

# ——— Firebase (FCM push) ———
FIREBASE_CREDENTIALS=/etc/secrets/firebase.json   # ملفّ سرّيّ في Render، أو محتوى JSON

# ——— وسيط الذكاء (اختياريّ) ———
ANTHROPIC_API_KEY=

# ——— CORS: أصل الواجهة الإنتاجيّة ———
# يُضبط في config/cors.php أو FRONTEND_URL حسب الحاجة
FRONTEND_URL=https://app.example.com
