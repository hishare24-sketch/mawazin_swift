APP_NAME="Smart Recruitment System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack

# ===== القاعدة =====
# الأسهل محليًّا: SQLite (ملف واحد، بلا خادم). أنشئ الملف: database/database.sqlite
DB_CONNECTION=sqlite
# للفريق/الإنتاج: Postgres عبر Docker — compose.yaml يضبط متغيّرات pgsql ويتجاوز هذا تلقائيًا.
# (لتشغيل Postgres محليًّا بدل SQLite، بدّل DB_CONNECTION=pgsql وفعّل الأسطر التالية)
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=recruitment
# DB_USERNAME=recruitment
# DB_PASSWORD=secret

# Sanctum — نطاق الواجهة المسموح
SANCTUM_STATEFUL_DOMAINS=localhost:5173
FRONTEND_URL=http://localhost:5173

# عربي أولًا
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
