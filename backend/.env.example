APP_NAME="Smart Recruitment System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=recruitment
DB_USERNAME=recruitment
DB_PASSWORD=secret

# Sanctum — نطاقات الواجهة المسموح لها
SANCTUM_STATEFUL_DOMAINS=localhost:5173
