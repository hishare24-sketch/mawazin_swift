# Normalize line endings to LF on checkin, keep native on checkout
* text=auto eol=lf

# Force LF for these source files
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.vue   text eol=lf
*.json  text eol=lf
*.scss  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Windows-specific scripts keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary files (no diff / no eol conversion)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   text
*.webp  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
*.mp4   binary
*.zip   binary
