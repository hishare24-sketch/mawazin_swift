# انسخ إلى .env في جذر المشروع ثم:
#   docker compose up -d --build
#
# افتح: http://localhost:8080  (أو http://<IP-السيرفر>:8080)

HTTP_PORT=8080
APP_NAME=منظومة التوظيف الذكية
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080

# مفتاح Laravel — غيّره في أي نشر حقيقي
# توليد بديل: docker compose run --rm api php artisan key:generate --show
APP_KEY=base64:UPVGp2N//IYcM8QaQPCpLFkUqbmMwHbhPBt9ZtnNCzs=

DB_DATABASE=recruitment
DB_USERNAME=recruitment
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

REVERB_APP_ID=mawazin
