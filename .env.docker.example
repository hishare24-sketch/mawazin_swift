# ===== بيئة Docker — sufha.com =====
#   cp .env.docker.example .env
#   docker compose up -d --build --remove-orphans
#
# الـ nginx المشترك (ubuntu-nginx-1) يعكس الدومين إلى alias: mawazin-swift

HTTP_BIND=127.0.0.1
HTTP_PORT=8088

# اسم شبكة Docker لمشروع nginx — عندكم: dashboard-net
NGINX_NETWORK=dashboard-net

DOMAIN=sufha.com

APP_NAME=منظومة التوظيف الذكية
APP_ENV=production
APP_DEBUG=false
APP_URL=https://sufha.com

APP_KEY=base64:UPVGp2N//IYcM8QaQPCpLFkUqbmMwHbhPBt9ZtnNCzs=

DB_DATABASE=recruitment
DB_USERNAME=recruitment
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

REVERB_APP_ID=mawazin
REVERB_APP_KEY=v6zvrzamckeajqmbcfn0
REVERB_APP_SECRET=local-reverb-secret-change-me

VITE_REVERB_SCHEME=https

# سوبر أدمن (Spatie super_admin) — يُنشأ عند bash deploy.sh
SUPER_ADMIN_EMAIL=owner@recruitment.app
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=Recruitment Owner
